# Copy this file to ".env" and fill in your own keys.
# Do NOT commit the real .env file (it is gitignored).

# Google Gemini API key (LLM for summarization/translation agents)
GOOGLE_API_KEY=your_google_gemini_api_key

# NewsAPI key (https://newsapi.org)
NEWS_API_KEY=your_newsapi_key

# Company Enrich API key (source logos)
COMPANY_ENRICH_API_KEY=your_company_enrich_api_key

# Google Cloud Translation API key
TRANSLATE_API=your_google_translate_api_key
